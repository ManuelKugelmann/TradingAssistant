# MCP Signals Stack — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ── MongoDB Atlas ──────────────────────────────
# Free M0 cluster: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/signals

# ── Profiles directory (default: ./profiles) ───
# PROFILES_DIR=./profiles

# ── API Keys (optional, for sources that need them) ──
# FRED_API_KEY=
# ACLED_API_KEY=
# ACLED_EMAIL=
# EIA_API_KEY=
# COMTRADE_API_KEY=
# GOOGLE_API_KEY=
# AISSTREAM_API_KEY=
# CF_API_TOKEN=
# USDA_NASS_API_KEY=
