{
  "$schema": "Profile schema for countries",
  "required": ["id", "name", "iso2", "region"],
  "properties": {
    "id": "ISO3 country code (e.g. DEU, USA)",
    "name": "Full country name",
    "iso2": "ISO2 code",
    "region": "Geographic region",
    "currency": "Primary currency ISO code",
    "capital": "Capital city",
    "population": "Approximate population",
    "trade": {
      "top_exports": "Main export commodities",
      "top_partners": "Key trade partner ISO3 codes",
      "major_ports": "Key port names",
      "chokepoint_exposure": "Shipping chokepoints (suez/hormuz/panama/malacca)"
    },
    "exposure": {
      "commodities_import": "Critical commodity imports",
      "energy_mix": "Energy source breakdown",
      "risk_factors": "Key risk categories"
    },
    "ratings": {
      "credit": "S&P/Moody's/Fitch sovereign rating",
      "democracy_index": "EIU Democracy Index score",
      "press_freedom_rank": "RSF rank",
      "corruption_perception": "TI CPI score"
    },
    "tags": "Array of group memberships (e.g. EU, G7, NATO)",
    "_updated": "ISO date of last update",
    "_sources": "Array of source labels"
  }
}
