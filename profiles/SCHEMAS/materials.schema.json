{
  "$schema": "Profile schema for raw materials",
  "required": ["id", "name", "category"],
  "properties": {
    "id": "Material identifier (lithium, copper, iron_ore, etc.)",
    "name": "Full name",
    "category": "metals | minerals | chemicals | forestry | textiles",
    "producers": "Array of top producer country ISO3 codes",
    "reserves": "Countries with major reserves (ISO3 codes)",
    "processing": "Key processing/refining countries",
    "end_uses": "Primary industrial applications",
    "substitutes": "Potential substitute materials",
    "exposure": {
      "countries": "Countries in supply chain",
      "risk_factors": "Supply concentration, geopolitical, environmental risks"
    },
    "tags": "Array of categorization tags",
    "_updated": "ISO date of last update",
    "_sources": "Array of source labels"
  }
}
