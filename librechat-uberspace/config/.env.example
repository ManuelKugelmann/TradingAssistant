# LibreChat — Environment Configuration
# setup.sh auto-generates crypto keys on first install.
# You only need to fill in MONGO_URI and at least one LLM provider.

# ── MongoDB (required) ─────────────────────────
# Free M0 cluster: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/LibreChat

# ── Crypto Keys (auto-generated by setup.sh) ───
CREDS_KEY=
CREDS_IV=
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── LLM Providers (at least one required) ──────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenRouter (alternative: multiple models via one key) ──
# OPENROUTER_API_KEY=sk-or-...

# ── Free LLM Providers (all have free tiers) ─
# See docs/llm-keys.md for full setup guide.
# GROQ_API_KEY=gsk_...              # https://console.groq.com/keys
# GEMINI_API_KEY=AI...              # https://aistudio.google.com/apikey
# XAI_API_KEY=xai-...               # https://console.x.ai
# MISTRAL_API_KEY=...               # https://console.mistral.ai/api-keys
# CEREBRAS_API_KEY=csk-...          # https://cloud.cerebras.ai
# COHERE_API_KEY=...                # https://dashboard.cohere.com/api-keys
# SAMBANOVA_API_KEY=...             # https://cloud.sambanova.ai
# HF_API_KEY=hf_...                 # https://huggingface.co/settings/tokens
# GITHUB_MODELS_PAT=ghp_...          # https://github.com/settings/tokens (no scopes needed)
# DASHSCOPE_API_KEY=sk-...           # https://dashscope.console.aliyun.com/apiKey (Qwen)

# ── Claude Max (subscription via CLIProxyAPI) ─
# Use your Claude Pro/Max subscription instead of API key billing.
# See docs/claude-token-wrapper.md for setup guide.
# Uncomment ENDPOINTS line and add 'custom' to enable.
# ENDPOINTS=openAI,anthropic,custom

# ── Features ───────────────────────────────────
SEARCH=false

# ── Signals Stack API Keys (optional) ──────────
# Only needed if you use the corresponding domain servers.
# Most sources (28 of 75+) need zero API key.
# Variable names must match librechat.yaml env: sections.
# FRED_API_KEY=
# ACLED_API_KEY=
# ACLED_EMAIL=
# EIA_API_KEY=
# COMTRADE_API_KEY=
# GOOGLE_API_KEY=
# AISSTREAM_API_KEY=
# CF_API_TOKEN=
# USDA_NASS_API_KEY=

# ── Signals Store MongoDB ──────────────────────
# Can reuse the same Atlas cluster with a different database name,
# or use a separate cluster. The signals store uses database "signals".
# MONGO_URI_SIGNALS=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/signals
